{
  "name": "supersurf-daemon",
  "version": "1.0.0",
  "description": "Daemon process for SuperSurf — coordinates multiple MCP sessions sharing one Chrome extension",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "supersurf-daemon": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "author": "The Media Masons",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidbuiltit/Supersurf.git",
    "directory": "daemon"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && npx tsx ../scripts/shared.bundle.ts daemon",
    "prepublishOnly": "cp ../LICENSE . && npm run clean && npm run build",
    "test": "vitest run",
    "test.watch": "vitest"
  },
  "dependencies": {
    "shared": "*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
